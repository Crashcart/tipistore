#!/bin/bash
# Pre-commit hook for Kali Hacker Bot
# Runs linting and formatting checks before commit
# Install with: git config core.hooksPath .githooks

set -e

echo "🔍 Running pre-commit checks..."

# Check if npm ci has been run
if [ ! -d "node_modules" ]; then
  echo "❌ node_modules not found. Run 'npm ci' first."
  exit 1
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|json)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "✓ No JS/JSON files to check"
  exit 0
fi

echo "📝 Files to check:"
echo "$STAGED_FILES" | sed 's/^/  - /'

# Check formatting with Prettier
echo ""
echo "🎨 Checking formatting with Prettier..."
if npm run format:check > /dev/null 2>&1; then
  echo "✓ Prettier check passed"
else
  echo "❌ Prettier formatting issues found"
  echo "   Run: npm run format"
  echo "   Then: git add [files] && git commit"
  exit 1
fi

# Check linting with ESLint
echo ""
echo "🔗 Checking code with ESLint..."
if npm run lint:check > /dev/null 2>&1; then
  echo "✓ ESLint check passed"
else
  echo "❌ ESLint violations found"
  echo "   Run: npm run lint"
  echo "   Then: git add [files] && git commit"
  exit 1
fi

# Check for console.log statements in staged code
echo ""
echo "🚫 Checking for debug code..."
CONSOLE_LOGS=$(git diff --cached -- '*.js' | grep '^\+.*console\.(log|warn|error|debug)' || true)
if [ ! -z "$CONSOLE_LOGS" ]; then
  echo "❌ Debug console statements found in staged code:"
  echo "$CONSOLE_LOGS"
  exit 1
fi
echo "✓ No debug code found"

# Check for hardcoded secrets
echo ""
echo "🔐 Checking for potential secrets..."
SECRETS=$(git diff --cached | grep -E '(password|secret|token|api[_-]?key|auth).*=.*["\x27]' || true)
if [ ! -z "$SECRETS" ]; then
  echo "⚠️  Potential secrets detected in staged code:"
  echo "$SECRETS"
  echo ""
  echo "Please ensure secrets are not committed. Use environment variables instead."
  exit 1
fi
echo "✓ No obvious secrets detected"

echo ""
echo "✅ All pre-commit checks passed!"
echo "   Proceeding with commit..."
