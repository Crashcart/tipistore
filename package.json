{
  "name": "kali-hacker-bot",
  "version": "1.0.0",
  "description": "Elite browser-based penetration testing terminal with Ollama and Kali Linux integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:perf": "jest tests/performance",
    "test:security": "npm audit --audit-level=moderate",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"**/*.{js,json,html,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,html,css,md}\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "dockerode": "^4.0.2",
    "axios": "^1.6.0",
    "express-static-gzip": "^2.1.7",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "html2pdf.js": "^0.10.1",
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.5.0",
    "@testing-library/dom": "^9.3.0",
    "supertest": "^6.3.0",
    "eslint": "^8.44.0",
    "eslint-plugin-security": "^1.7.1",
    "prettier": "^3.0.0"
  }
}
