# Kali Hacker Bot Configuration

# Server
NODE_ENV=production
PORT=31337

# Ollama (running on host)
OLLAMA_URL=http://host.docker.internal:11434

# Docker
KALI_CONTAINER=kali-linux

# Security
ADMIN_PASSWORD=kalibot
AUTH_SECRET=changeme-generate-random-uuid

# Logging
LOG_LEVEL=info

# Windows MCP Server Configuration
# Docker socket for MCP server connection
# Windows (Docker Desktop): npipe:////./pipe/docker_engine
# Linux/WSL2: /var/run/docker.sock
# Remote HTTP: http://remote-host:2375 or https://remote-host:2376
MCP_DOCKER_SOCKET=npipe:////./pipe/docker_engine

# Kali container name for MCP server
MCP_KALI_CONTAINER=kali-linux

# MCP server logging level (error, warn, info, debug)
MCP_LOG_LEVEL=info
