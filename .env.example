# Kali Hacker Bot Configuration

# Server
NODE_ENV=production
PORT=31337
BIND_HOST=0.0.0.0
# BIND_HOST options:
#   0.0.0.0 = Listen on all interfaces (recommended for remote access)
#   localhost = Listen on loopback only (local access only)
#   <IP> = Bind to specific IP address

# Ollama (running on host)
OLLAMA_URL=http://host.docker.internal:11434

# Docker
KALI_CONTAINER=Kali-AI-linux

# Security
ADMIN_PASSWORD=kalibot
AUTH_SECRET=changeme-generate-random-uuid

# Logging
LOG_LEVEL=info
